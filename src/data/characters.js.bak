export function getCharacter(id) {
  return characters.find((c) => c.id === id);
}

export function getCharactersByPeriod(period) {
  return characters.filter((c) => c.period === period);
}

export const periods = [
  "창조 시대",
  "홍수 시대",
  "족장 시대",
  "출애굽 시대",
  "정복 시대",
  "사사 시대",
  "왕국 시대",
  "분열 왕국 시대",
  "포로 시대",
  "신약 시대",
];
